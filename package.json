{
  "name": "splashemout-turbo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:clean": "pkill -f '([n]ext dev|[n]ext start|[r]eact-scripts start|[v]ite( |$)|[t]urbo run dev|[p]npm dev|[n]pm run dev|[y]arn dev)' || true",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "env:secrets": "node scripts/generate-env-secrets.mjs",
    "check-types": "turbo run check-types",
    "typecheck": "pnpm check-types",
    "test": "turbo run test",
    "check": "pnpm format && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "clean:workspace": "sh scripts/clean-workspace.sh",
    "clean:install": "node scripts/clean-install.mjs && pnpm i",
    "validate": "pnpm check"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0 <12"
  }
}
