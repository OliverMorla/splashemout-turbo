# ─────────────────────────────────────────────
# App — Next.js / Vercel
# ─────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Auth — Better Auth
# Generate a strong secret:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
# ─────────────────────────────────────────────
BETTER_AUTH_SECRET=replace-with-generated-secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────
# Database — Supabase Postgres / Drizzle
# Use SUPABASE_DB_URL as the direct connection for migrations.
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/splashemout
SUPABASE_DB_URL=postgresql://postgres:password@localhost:5432/splashemout
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# ─────────────────────────────────────────────
# Email — Resend
# ─────────────────────────────────────────────
RESEND_API_KEY=re_replace-with-resend-api-key
RESEND_AUDIENCE_ID=replace-with-resend-audience-id
RESEND_FROM_EMAIL=hello@example.com
RESEND_FROM_NAME=splashemout

# ─────────────────────────────────────────────
# Payments — Stripe
# ─────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace-with-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-stripe-webhook-secret
STRIPE_PRICE_ID=price_replace-with-stripe-price-id
STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/replace-with-portal-link
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# ─────────────────────────────────────────────
# Analytics — PostHog
# ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_replace-with-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=replace-with-posthog-personal-api-key
POSTHOG_PROJECT_ID=replace-with-posthog-project-id

# ─────────────────────────────────────────────
# Error Monitoring — Sentry
# ─────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://public-key@o000000.ingest.sentry.io/000000
SENTRY_AUTH_TOKEN=replace-with-sentry-auth-token
SENTRY_ORG=replace-with-sentry-org
SENTRY_PROJECT=replace-with-sentry-project

# ─────────────────────────────────────────────
# CMS — Payload or Sanity
# Generate Payload secret: 
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
# ─────────────────────────────────────────────
PAYLOAD_SECRET=replace-with-generated-secret
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_CONFIG_PATH=src/payload.config.ts

# ─────────────────────────────────────────────
# Background Jobs — Inngest
# ─────────────────────────────────────────────
INNGEST_EVENT_KEY=replace-with-inngest-event-key
INNGEST_SIGNING_KEY=replace-with-inngest-signing-key

# ─────────────────────────────────────────────
# Object Storage — Cloudflare R2 (choose R2 or S3, not both)
# ─────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
CLOUDFLARE_R2_BUCKET=splashemout-assets
CLOUDFLARE_R2_PUBLIC_URL=https://assets.example.com

# ─────────────────────────────────────────────
# Object Storage — S3-Compatible Aliases (choose R2 or S3, not both)
# Use these only for libraries that expect AWS variable names.
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=replace-with-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-secret-access-key
AWS_REGION=auto
AWS_S3_BUCKET=splashemout-assets
AWS_S3_ENDPOINT=https://replace-with-account-id.r2.cloudflarestorage.com

# ─────────────────────────────────────────────
# AI Providers — OpenRouter / OpenAI / Anthropic
# Use later, after safety and compliance rules are in place.
# OpenRouter can route requests to multiple model providers.
# ─────────────────────────────────────────────
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-replace-with-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENAI_API_KEY=sk-proj-replace-with-openai-api-key
ANTHROPIC_API_KEY=sk-ant-replace-with-anthropic-api-key

# ─────────────────────────────────────────────
# Identity Verification — Persona
# Use later for therapist onboarding, not normal user signup.
# ─────────────────────────────────────────────
PERSONA_API_KEY=replace-with-persona-api-key
PERSONA_WEBHOOK_SECRET=replace-with-persona-webhook-secret
PERSONA_TEMPLATE_ID=itmpl_replace-with-template-id

# ─────────────────────────────────────────────
# Marketing Site — Webflow
# Optional if the app needs to sync marketing-site data.
# Values come from the Webflow dashboard.
# ─────────────────────────────────────────────
WEBFLOW_SITE_ID=replace-with-webflow-site-id
WEBFLOW_API_TOKEN=replace-with-webflow-api-token
